# %% [markdown]
# # Data Preparation Pipeline - Used Car Price Prediction
# 
# **Цель**: Преобразование сырых данных в формат, готовый для обучения модели
# 
# **Выход**: 
# - `data/processed/processed_cars.csv` - обработанные данные
# - `models/*.joblib` - сохраненные энкодеры и скейлеры

# %% [code]
import os
import numpy as np
import pandas as pd
import joblib
import matplotlib.pyplot as plt
import seaborn as sns

# Настройки
pd.set_option('display.max_columns', None)
sns.set_theme(style="whitegrid")

print("=" * 60)
print("DATA PREPARATION PIPELINE")
print("=" * 60)

# %% [markdown]
# ## 1. Configuration & Path Setup

# %% [code]
# Конфигурация путей
INPUT_PATH = "../data/sample_7.csv"
OUTPUT_DIR = "../data/processed"
OUTPUT_FILE = os.path.join(OUTPUT_DIR, "processed_cars.csv")
MODELS_DIR = "../models"

# Создаем директории
os.makedirs(OUTPUT_DIR, exist_ok=True)
os.makedirs(MODELS_DIR, exist_ok=True)

print(f"Input path:  {INPUT_PATH}")
print(f"Output path: {OUTPUT_FILE}")
print(f"Models path: {MODELS_DIR}")

# %% [markdown]
# ## 2. Load Raw Data

# %% [code]
# Загрузка данных
df = pd.read_csv(INPUT_PATH)

print(f"\nDataset loaded:")
print(f"   - Shape: {df.shape[0]} rows, {df.shape[1]} columns")
print(f"\nFirst 5 rows:")
df.head()

# %% [code]
print("\nData types:")
print(df.dtypes)

print("\nMissing values before processing:")
print(df.isnull().sum()[df.isnull().sum() > 0])

# %% [markdown]
# ## 3. Phase 1: Cleaning & Imputation

# %% [code]
# Удаляем строки без целевой переменной или даты
initial_rows = len(df)
df = df.dropna(subset=['sellingprice', 'saledate'])
print(f"Rows after dropping missing target/saledate: {len(df)} (removed {initial_rows - len(df)})")

# %% [code]
# Импутация odometer - медиана по году выпуска
df['odometer'] = df.groupby('year')['odometer'].transform(
    lambda x: x.fillna(x.median() if not x.dropna().empty else df['odometer'].median())
)
# Заполняем оставшиеся пропуски глобальной медианой
df['odometer'] = df['odometer'].fillna(df['odometer'].median())
print("odometer imputed")

# Импутация condition - медиана по году выпуска
df['condition'] = df.groupby('year')['condition'].transform(
    lambda x: x.fillna(x.median() if not x.dropna().empty else df['condition'].median())
)
df['condition'] = df['condition'].fillna(df['condition'].median())
print("condition imputed")

# %% [code]
# Импутация категориальных признаков
cat_cols = ['make', 'model', 'trim', 'body', 'transmission', 'state', 'color', 'interior', 'seller']
for col in cat_cols:
    df[col] = df[col].fillna('Unknown').astype(str).str.lower().str.strip()

print("categorical columns imputed")
print(f"\nMissing values after imputation:")
print(df.isnull().sum()[df.isnull().sum() > 0] if any(df.isnull().sum() > 0) else "No missing values left!")

# %% [markdown]
# ## 4. Phase 2: Feature Engineering (Temporal Features)

# %% [code]
# Парсинг даты продажи
df['saledate_clean'] = df['saledate'].str.split(' GMT').str[0]
df['saledate_clean'] = pd.to_datetime(
    df['saledate_clean'], 
    format='%a %b %d %Y %H:%M:%S', 
    errors='coerce'
)

# Извлечение временных признаков
df['sale_year'] = df['saledate_clean'].dt.year
df['sale_month'] = df['saledate_clean'].dt.month
df['sale_day_of_week'] = df['saledate_clean'].dt.dayofweek

# Заполнение пропусков в временных признаках
for col in ['sale_year', 'sale_month', 'sale_day_of_week']:
    mode_val = df[col].mode()
    if not mode_val.empty:
        df[col] = df[col].fillna(mode_val[0])
    else:
        df[col] = df[col].fillna(0)

print("temporal features extracted:")
print(f"   - sale_year (range: {df['sale_year'].min()} - {df['sale_year'].max()})")
print(f"   - sale_month (range: {df['sale_month'].min()} - {df['sale_month'].max()})")
print(f"   - sale_day_of_week (0=Monday, 6=Sunday)")

# %% [markdown]
# ## 5. Phase 3: Feature Selection & Encoding Setup

# %% [code]
# Определяем признаки для модели
model_features = [
    'year', 'make', 'model', 'trim', 'body', 'transmission',
    'state', 'condition', 'odometer', 'color', 'interior',
    'sale_year', 'sale_month', 'sale_day_of_week', 'sellingprice'
]

proc = df[model_features].copy()
print(f"Selected {len(model_features) - 1} features + target")

# %% [code]
# Разделяем типы признаков
numerical_features = ['year', 'condition', 'odometer', 'sale_year', 'sale_month', 'sale_day_of_week']
categorical_low_card = ['body', 'transmission']      # One-Hot Encoding
categorical_high_card = ['make', 'model', 'trim', 'state', 'color', 'interior']  # Ordinal Encoding

print(f"\nFeature categorization:")
print(f"   Numerical ({len(numerical_features)}):      {numerical_features}")
print(f"   Low cardinality ({len(categorical_low_card)}):   {categorical_low_card}")
print(f"   High cardinality ({len(categorical_high_card)}): {categorical_high_card}")

# %% [markdown]
# ## 6. Phase 4: Encoding & Scaling

# %% [code]
# --- StandardScaler for numerical features ---
from sklearn.preprocessing import StandardScaler, OneHotEncoder, OrdinalEncoder

scaler = StandardScaler()
numerical_scaled = scaler.fit_transform(proc[numerical_features])
print(f"StandardScaler fitted on {len(numerical_features)} features")
print(f"   - Means: {scaler.mean_[:3]}...")
print(f"   - Stds:  {scaler.scale_[:3]}...")

# %% [code]
# --- One-Hot Encoding for low-cardinality features ---
ohe = OneHotEncoder(handle_unknown='ignore', sparse_output=False, drop='first')
ohe_transformed = ohe.fit_transform(proc[categorical_low_card])
ohe_cols = list(ohe.get_feature_names_out(categorical_low_card))

print(f"\nOneHotEncoder fitted on {len(categorical_low_card)} features")
print(f"   - Output columns: {len(ohe_cols)}")
print(f"   - Columns: {ohe_cols[:5]}...")

# %% [code]
# --- Ordinal Encoding for high-cardinality features ---
ordinal_enc = OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1)
ordinal_transformed = ordinal_enc.fit_transform(proc[categorical_high_card])

print(f"\nOrdinalEncoder fitted on {len(categorical_high_card)} features")
print(f"   - Categories per feature:")
for i, col in enumerate(categorical_high_card):
    n_cats = len(ordinal_enc.categories_[i])
    print(f"     * {col}: {n_cats} unique values")

# %% [markdown]
# ## 7. Phase 5: Combine Processed Data

# %% [code]
# Сборка финального DataFrame
final_df = pd.DataFrame(
    np.hstack([numerical_scaled, ohe_transformed, ordinal_transformed]),
    columns=numerical_features + ohe_cols + categorical_high_card
)
final_df['sellingprice'] = proc['sellingprice'].values

print(f"\nProcessed dataset created:")
print(f"   - Shape: {final_df.shape}")
print(f"   - Features: {final_df.shape[1] - 1} (excluding target)")
print(f"\nFirst 5 rows (processed):")
final_df.head()

# %% [code]
print("\nProcessed data info:")
print(f"   - Missing values: {final_df.isnull().sum().sum()}")
print(f"   - Memory usage: {final_df.memory_usage(deep=True).sum() / 1024**2:.2f} MB")

# %% [markdown]
# ## 8. Phase 6: Save Output Assets

# %% [code]
# Сохраняем processed dataset
final_df.to_csv(OUTPUT_FILE, index=False)
print(f"Processed data saved to: {OUTPUT_FILE}")

# %% [markdown]
# ## 9. Phase 7: Save Encoders for Backend (CRITICAL for Week 6!)

# %% [code]
# Сохраняем fitted encoders для использования в backend
print("\n" + "=" * 60)
print("SAVING ENCODERS FOR BACKEND")
print("=" * 60)

# Сохраняем scaler
joblib.dump(scaler, os.path.join(MODELS_DIR, "scaler.joblib"))
print(f"scaler.joblib saved to {MODELS_DIR}/")

# Сохраняем OneHotEncoder
joblib.dump(ohe, os.path.join(MODELS_DIR, "onehot_encoder.joblib"))
print(f"onehot_encoder.joblib saved to {MODELS_DIR}/")

# Сохраняем OrdinalEncoder
joblib.dump(ordinal_enc, os.path.join(MODELS_DIR, "ordinal_encoder.joblib"))
print(f"ordinal_encoder.joblib saved to {MODELS_DIR}/")

# Сохраняем список колонок (важно для порядка!)
feature_columns = [c for c in final_df.columns if c != 'sellingprice']
joblib.dump(feature_columns, os.path.join(MODELS_DIR, "feature_columns.joblib"))
print(f"feature_columns.joblib saved to {MODELS_DIR}/ (shape: {len(feature_columns)})")

# Сохраняем маппинг признаков для воспроизводимости
feature_mapping = {
    'numerical_features': numerical_features,
    'ohe_features': categorical_low_card,
    'ordinal_features': categorical_high_card,
    'ohe_cols': ohe_cols,
    'target': 'sellingprice'
}
joblib.dump(feature_mapping, os.path.join(MODELS_DIR, "feature_mapping.joblib"))
print(f"feature_mapping.joblib saved to {MODELS_DIR}/")

# %% [markdown]
# ## 10. Phase 8: Verification & Sanity Check

# %% [code]
print("\n" + "=" * 60)
print("VERIFICATION & SANITY CHECK")
print("=" * 60)

# Проверка загрузки энкодеров
print("\nTesting encoder reload...")

test_scaler = joblib.load(os.path.join(MODELS_DIR, "scaler.joblib"))
test_ohe = joblib.load(os.path.join(MODELS_DIR, "onehot_encoder.joblib"))
test_ordinal = joblib.load(os.path.join(MODELS_DIR, "ordinal_encoder.joblib"))
test_columns = joblib.load(os.path.join(MODELS_DIR, "feature_columns.joblib"))
test_mapping = joblib.load(os.path.join(MODELS_DIR, "feature_mapping.joblib"))

# Проверяем, что reloaded объекты дают тот же результат
sample_idx = 0
sample_raw = proc.iloc[[sample_idx]]

# Re-apply transformations using reloaded encoders
num_scaled_reloaded = test_scaler.transform(sample_raw[numerical_features])
ohe_reloaded = test_ohe.transform(sample_raw[categorical_low_card])
ordinal_reloaded = test_ordinal.transform(sample_raw[categorical_high_card])

result_reloaded = np.hstack([num_scaled_reloaded, ohe_reloaded, ordinal_reloaded])
original_result = np.hstack([numerical_scaled[sample_idx:sample_idx+1], 
                              ohe_transformed[sample_idx:sample_idx+1], 
                              ordinal_transformed[sample_idx:sample_idx+1]])

if np.allclose(result_reloaded, original_result):
    print("SUCCESS: Reloaded encoders produce IDENTICAL results to original!")
else:
    print("ERROR: Reloaded encoders produce different results!")

# %% [code]
print("\nFinal summary:")
print(f"   - Processed data shape: {final_df.shape}")
print(f"   - Feature columns count: {len(feature_columns)}")
print(f"\nSaved files in {MODELS_DIR}/:")
for f in os.listdir(MODELS_DIR):
    if f.endswith('.joblib'):
        size = os.path.getsize(os.path.join(MODELS_DIR, f)) / 1024
        print(f"   - {f}: {size:.1f} KB")

# %% [code]
